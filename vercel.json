{
  "rewrites": [
    {
      "source": "/property/:id",
      "destination": "/api/og-redirect"
    },
    {
      "source": "/he/property/:id",
      "destination": "/api/og-redirect"
    },
    {
      "source": "/en/property/:id",
      "destination": "/api/og-redirect"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
